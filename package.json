{
  "name": "uzumaki",
  "module": "index.ts",
  "type": "module",
  "workspaces": [
    "crates/uzumaki_core",
    "packages/*"
  ],
  "private": true,
  "scripts": {
    "start": "pnpm build:core && pnpm --filter playground start",
    "build:core": "pnpm --filter uzumaki build",
    "build:experimental": "cargo build --release -p uzumaki_core_exp && bun scripts/copy-binary.ts --release",
    "start:experimental": "pnpm build:experimental && pnpm --filter playground-exp start",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
