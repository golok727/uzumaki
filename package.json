{
  "name": "uzumaki-monorepo",
  "description": "React Desktop UI Framework without the browser stuff",
  "type": "module",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "scripts": {
    "dev": "pnpm build && pnpm --filter playground dev",
    "build": "cargo build --release -p uzumaki",
    "dev:docs": "pnpm --filter docs dev",
    "format": "prettier --write .",
    "lint": "oxlint --react-plugin --node-plugin .",
    "typecheck": "pnpm -r typecheck",
    "gen:types": "bun scripts/generate-types",
    "lint:fix": "oxlint --react-plugin --node-plugin --fix .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": [
      "prettier --ignore-unknown --write",
      "oxlint --react-plugin --node-plugin --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.rs": [
      "cargo fmt --"
    ]
  },
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.2"
  }
}
