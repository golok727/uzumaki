{
  "version": "0.0.0",
  "name": "playground",
  "type": "module",
  "private": true,
  "dependencies": {
    "react": "^19.2.6",
    "shiki": "^4.0.2",
    "uzumaki-react": "workspace:*"
  },
  "scripts": {
    "dev": "cargo r -p uzumaki --release -- src/index.tsx",
    "build": "pnpm build:js && cargo r -p uzumaki --release -- build",
    "build:js": "cargo r -p uzumaki --release -- run build.ts",
    "preview": "cargo r -p uzumaki --release -- dist/index.js",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "rolldown": "^1.0.0",
    "typescript": "^5",
    "uzumaki-types": "workspace:*"
  }
}
