{
  "name": "playground",
  "type": "module",
  "private": true,
  "dependencies": {
    "react": "^19.2.4",
    "shiki": "^4.0.2",
    "uzumaki-ui": "workspace:*"
  },
  "scripts": {
    "dev": "cargo r -p uzumaki --release -- src/index.tsx",
    "build": "cargo r -p uzumaki --release -- build",
    "build:js": "bun build src/index.tsx --target node --outdir dist --minify",
    "preview": "cargo r -p uzumaki --release -- dist/index.js",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "uzumaki-types": "workspace:*",
    "typescript": "^5"
  }
}
