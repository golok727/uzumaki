{
  "name": "uzumaki-ui",
  "type": "module",
  "version": "0.0.1",
  "bin": {
    "uzumaki": "./cli/main.ts"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "exports": {
    ".": "./js/index.ts",
    "./react": "./js/react/index.ts",
    "./react/jsx-runtime": "./js/react/jsx/runtime.ts",
    "./react/jsx-dev-runtime": "./js/react/jsx/dev-runtime.ts"
  },
  "napi": {
    "binaryName": "uzumaki"
  },
  "files": [
    "cli/**/*",
    "README.md",
    "bin/**/*",
    "js/**/*"
  ],
  "keywords": [
    "desktop",
    "ui",
    "react",
    "native",
    "gpu",
    "wgpu",
    "vello"
  ],
  "scripts": {
    "start": "bun js/index.js",
    "build": "napi build --release --platform -o ./js/bindings",
    "build:debug": "napi build"
  },
  "dependencies": {
    "react-reconciler": "^0.33.0"
  },
  "optionalDependencies": {
    "@uzumaki-apps/win32-x64": "workspace:*"
  }
}
